# MCP Gateway Environment Configuration
# Copy this file to .env and fill in your values

# MySQL Configuration
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=mcp_gateway

# Spring Boot Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/mcp_gateway?useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=secret

# Encryption Master Key (Base64-encoded 32-byte AES key)
# Generate with: openssl rand -base64 32
# Default for development only:
MCP_GATEWAY_MASTER_KEY=aGVsbG8gd29ybGQgdGhpcyBpcyBhIHRlc3Qga2V5IGZvciBkZXZlbG9wbWVudA==

# Spring Profiles
SPRING_PROFILES_ACTIVE=dev

# API Configuration
SERVER_PORT=8080

# Logging
LOGGING_LEVEL_COM_MCPGATEWAY=DEBUG

